# API GitHub — https://github.com/settings/tokens (lecture publique suffit pour les repos publics)
GITHUB_TOKEN=

# --- Analyse générative (optionnelle) : désactivée par défaut (aucune install requise) ---
# Pour activer : LLM_ENABLED=true puis l’une des options ci-dessous.
#
# Option A — Ollama (local, gratuit) :
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
#
# Option B — OpenAI (facturation possible) : OPENAI_API_KEY suffit (pas besoin de LLM_PROVIDER).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Next.js (SSR) → API NestJS en local (port 3001)
INTERNAL_API_URL=http://127.0.0.1:3001

# Backend (plus tard : PostgreSQL / Redis)
# DATABASE_URL=postgresql://devscope:devscope@localhost:5432/devscope
# REDIS_URL=redis://localhost:6379
